{
  "name": "Codex CLI Dev Environment",

  // ベースイメージ（Ubuntu + 共通ツール）
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",

  // Dev Container Features で言語・ツールを追加
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22",
      "nodeGypDependencies": true
    },
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.12",
      "installTools": true
    },
    "ghcr.io/devcontainers/features/rust:1": {
      "version": "latest",
      "profile": "default"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/git:1": {
      "version": "latest",
      "ppa": true
    }
  },

  // ホスト側に ~/.codex が無い場合に備えて事前作成 → Codex CLI + pnpm インストール
  "initializeCommand": "mkdir -p ${localEnv:HOME}/.codex",
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y bubblewrap && npm install -g @openai/codex pnpm && echo 'Dev container ready!'",

  // Mac の ~/.codex をコンテナにマウント（個人設定・認証を引き継ぐ）
  "mounts": [
    "source=${localEnv:HOME}/.codex,target=/home/vscode/.codex,type=bind,consistency=cached"
  ],

  // VS Code 拡張機能（チーム共通）
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-python.python",
        "rust-lang.rust-analyzer"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh"
      }
    }
  },

  // コンテナ内のポートフォワーディング（開発サーバー用）
  "forwardPorts": [3000, 5173, 8000],

  // 非 root ユーザーで実行
  "remoteUser": "vscode"
}
